# ──────────────────────────────────────────────────────────────────────────────
# SAIOMS — Environment Variables Template
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to git — it contains secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# MongoDB connection URI (local or Atlas)
MONGO_URI=mongodb://localhost:27017
DB_NAME=saioms

# JWT secret — MUST be a long random string (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_SECRET_HERE
JWT_EXPIRES_IN=7d

# QR code signing secrets (must match ml-service values)
QR_SECRET=CHANGE_ME_QR_SECRET
QR_SALT=CHANGE_ME_QR_SALT

# ── OPTIONAL — FEATURE FLAGS ───────────────────────────────────────────────────

# Gemini API key (enables AI breed detection fallback + nearby search helper)
# Get free key at: https://ai.google.dev
GEMINI_API_KEY=

# SerpAPI key (enables Google Maps data in nearby search: phone, rating, hours)
# Get key at: https://serpapi.com (100 free searches/month on free tier)
SERPAPI_KEY=

# ML service URL (default: local dev)
ML_SERVICE_URL=http://localhost:8001

# Backend port
PORT=5000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# ── FRONTEND ──────────────────────────────────────────────────────────────────
# Set this in frontend/.env (not here)
# VITE_API_BASE_URL=http://localhost:5000
